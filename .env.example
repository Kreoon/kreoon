# Supabase Configuration
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"

# Supabase Service Role Key (acceso total, bypasea RLS - NUNCA exponer en frontend)
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Supabase Access Token (para CLI: deploy de funciones y migraciones)
# SUPABASE_ACCESS_TOKEN="your-access-token"

# Note: The following variables are used in Edge Functions (supabase/functions/)
# and should be configured in Supabase Dashboard > Settings > Edge Functions

# AI Providers (configured in Edge Functions)
# PERPLEXITY_API_KEY=
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Bunny CDN (configured in Edge Functions)
# BUNNY_API_KEY=
# BUNNY_LIBRARY_ID=
# BUNNY_STORAGE_ZONE=

# External Integrations (configured in Edge Functions)
# N8N_WEBHOOK_URL=
# GHL_API_KEY=
# RESTREAM_API_KEY=

# ============ SECURITY SECRETS (REQUIRED - NO DEFAULTS) ============
# These MUST be configured in Supabase Dashboard > Settings > Edge Functions
# Generate strong random values for each (e.g., openssl rand -hex 32)

# Admin/Bootstrap Functions
# ROOT_ADMIN_EMAIL=your-admin@email.com
# ROOT_ADMIN_PASSWORD=<strong-random-password>
# ROOT_ADMIN_EMAILS=admin1@email.com,admin2@email.com
# KREOON_BOOTSTRAP_SECRET=<random-32-char-string>
# EMERGENCY_PASSWORD_RESET_SECRET=<random-32-char-string>
# KREOON_ROOT_AUTH_ID=<uuid-of-root-admin-in-auth>
# DEFAULT_ORGANIZATION_ID=<uuid-of-default-organization>

# Sync Functions
# PANCAKE_SYNC_SECRET=<random-32-char-string>
# KREOON_SQL_EXEC_SECRET=<random-32-char-string>

# Bunny CDN TUS Upload (optional but recommended)
# BUNNY_TUS_SECRET=<random-32-char-string>
